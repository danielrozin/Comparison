# Database
DATABASE_URL="postgresql://user:password@localhost:5432/comparison"

# Upstash Redis (required for admin panel & persistent tracking)
# Get these from: https://console.upstash.com/ or Vercel Storage dashboard
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# DataForSEO (server-side only — never expose in browser)
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# App
NEXT_PUBLIC_SITE_URL="https://www.aversusb.net"
NEXT_PUBLIC_SITE_NAME="A Versus B"

# Anthropic Claude API (for AI comparison generation — server-side only)
ANTHROPIC_API_KEY=""

# Tavily API (for real-time web data enrichment — server-side only)
TAVILY_API_KEY=""

# Apify API (for competitor scraping & content gap analysis — server-side only)
APIFY_API_TOKEN=""

# Google Search Console (service account JSON key, stringified)
GOOGLE_SERVICE_ACCOUNT_KEY=""

# Cron secret (set this in Vercel project settings to secure cron endpoints)
CRON_SECRET=""

# Admin token (for admin panel and protected API endpoints)
ADMIN_TOKEN=""
