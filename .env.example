# Database
# Runtime/queries use the pooled (PgBouncer, `-pooler` host) endpoint.
DATABASE_URL="postgresql://user:password@localhost:5432/comparison"
# Migrations (prisma migrate deploy) use the DIRECT, non-pooled endpoint.
# Same as DATABASE_URL but with `-pooler` removed from the host (Neon).
# Required by the `directUrl` in prisma/schema.prisma. See DAN-1512.
DIRECT_URL="postgresql://user:password@localhost:5432/comparison"

# Upstash Redis (required for admin panel & persistent tracking)
# Get these from: https://console.upstash.com/ or Vercel Storage dashboard
KV_REST_API_URL=""
KV_REST_API_TOKEN=""

# DataForSEO (server-side only — never expose in browser)
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""

# App
NEXT_PUBLIC_SITE_URL="https://www.aversusb.net"
NEXT_PUBLIC_SITE_NAME="A Versus B"
NEXT_PUBLIC_SURVEY_URL="/survey"

# Anthropic Claude API (for AI comparison generation — server-side only)
ANTHROPIC_API_KEY=""

# Tavily API (for real-time web data enrichment — server-side only)
TAVILY_API_KEY=""

# Apify API (for competitor scraping & content gap analysis — server-side only)
APIFY_API_TOKEN=""

# Google Search Console (service account JSON key, stringified)
GOOGLE_SERVICE_ACCOUNT_KEY=""

# Resend (PRIMARY transport for outreach, transactional & admin notifications — requires verified domain)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="A Versus B <noreply@aversusb.net>"
# Where admin form/feedback/newsletter notifications are delivered (DAN-1204).
# Defaults to daniarozin@gmail.com if unset.
ADMIN_NOTIFICATION_EMAIL="daniarozin@gmail.com"
# Web3Forms is only a best-effort FALLBACK for admin notifications; its API
# ignores the `to` field and always delivers to the access-key owner's mailbox.
WEB3FORMS_ACCESS_KEY=""

# ElevenLabs (TTS narration + speech-to-text for HyperFrames video pipeline)
ELEVENLABS_API_KEY=""
# Optional overrides:
# ELEVENLABS_VOICE_ID="JBFqnCBsd6RMkjVDRZzb"   # Default: George (narrator)
# ELEVENLABS_MODEL_ID="eleven_v3"              # Default: eleven_v3 (most expressive)

# Cron secret (set this in Vercel project settings to secure cron endpoints)
CRON_SECRET=""

# Admin token (for admin panel and protected API endpoints)
ADMIN_TOKEN=""

# Google Tag Manager (optional — if set, replaces raw gtag.js)
NEXT_PUBLIC_GTM_ID=""

# GA4 Measurement ID (fallback if GTM not configured)
NEXT_PUBLIC_GA_ID="G-0BWYZ5V9QK"

# Google Ads account ID (e.g. AW-XXXXXXXXX)
NEXT_PUBLIC_GOOGLE_ADS_ID=""

# Google Ads contact-form conversion label (e.g. AW-XXXXXXXXX/abc123DEF456).
# Optional — when set, contact form submissions fire a dedicated Google Ads conversion.
# Leave empty until the ad account is live; GA4 generate_lead is tracked regardless.
NEXT_PUBLIC_GOOGLE_ADS_CONTACT_LABEL=""

# Meta Pixel ID (for Facebook/Instagram remarketing)
NEXT_PUBLIC_META_PIXEL_ID=""

# Affiliate Links (Amazon Associates)
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=""
NEXT_PUBLIC_AFFILIATE_ENABLED="false"

# Sentry Error Tracking
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
