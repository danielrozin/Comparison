generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENTITY SYSTEM — The core knowledge graph
// ============================================================

model EntityType {
  id          String   @id @default(cuid())
  slug        String   @unique // "person", "country", "product", "team", etc.
  name        String   // "Person", "Country", "Product"
  description String?
  icon        String?  // emoji or icon name
  parentId    String?  @map("parent_id")
  parent      EntityType?  @relation("EntityTypeHierarchy", fields: [parentId], references: [id])
  children    EntityType[] @relation("EntityTypeHierarchy")

  entities    Entity[]
  attributes  Attribute[]

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("entity_types")
}

model Entity {
  id            String   @id @default(cuid())
  slug          String   @unique // "lionel-messi", "japan", "iphone-15"
  name          String   // "Lionel Messi", "Japan", "iPhone 15"
  shortDesc     String?  @map("short_desc") // one-liner
  description   String?  // longer description
  imageUrl      String?  @map("image_url")
  thumbnailUrl  String?  @map("thumbnail_url")
  entityTypeId  String   @map("entity_type_id")
  entityType    EntityType @relation(fields: [entityTypeId], references: [id])

  // Metadata (flexible JSON for type-specific data)
  metadata      Json?    @default("{}")

  // Relationships
  attributeValues  AttributeValue[]
  comparisonsA     ComparisonEntity[] @relation("ComparisonEntityA")
  faqs             FAQ[]
  internalLinksFrom InternalLink[] @relation("InternalLinkFrom")
  internalLinksTo   InternalLink[] @relation("InternalLinkTo")
  productReviews    ProductReview[]
  reviewAggregation ReviewAggregation?
  affiliateLinks    AffiliateLink[]
  affiliateClicks   AffiliateClick[]

  // SEO
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")

  // Status
  status          String   @default("draft") // draft, published, archived
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([entityTypeId])
  @@index([status])
  @@index([slug])
  @@map("entities")
}

// ============================================================
// ATTRIBUTE SYSTEM — Structured comparison dimensions
// ============================================================

model Attribute {
  id            String   @id @default(cuid())
  slug          String   // "height", "population", "price"
  name          String   // "Height", "Population", "Price"
  description   String?
  unit          String?  // "cm", "people", "USD"
  dataType      String   @default("text") @map("data_type") // text, number, boolean, date, list, json
  category      String?  // grouping: "Physical", "Economic", "Technical"
  sortOrder     Int      @default(0) @map("sort_order")
  entityTypeId  String   @map("entity_type_id")
  entityType    EntityType @relation(fields: [entityTypeId], references: [id])
  isComparable  Boolean  @default(true) @map("is_comparable")
  higherIsBetter Boolean? @map("higher_is_better") // for numeric comparisons

  values        AttributeValue[]

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([slug, entityTypeId])
  @@index([entityTypeId])
  @@map("attributes")
}

model AttributeValue {
  id           String   @id @default(cuid())
  entityId     String   @map("entity_id")
  entity       Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  attributeId  String   @map("attribute_id")
  attribute    Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  valueText    String?  @map("value_text")
  valueNumber  Float?   @map("value_number")
  valueBoolean Boolean? @map("value_boolean")
  valueDate    DateTime? @map("value_date")
  valueJson    Json?    @map("value_json")

  source       String?  // where the data came from
  confidence   Float?   @default(1.0) // 0-1 confidence score
  asOfDate     DateTime? @map("as_of_date") // when this value was accurate

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([entityId, attributeId])
  @@index([entityId])
  @@index([attributeId])
  @@map("attribute_values")
}

// ============================================================
// COMPARISON SYSTEM — The core content pages
// ============================================================

model Comparison {
  id            String   @id @default(cuid())
  slug          String   @unique // "messi-vs-ronaldo"
  title         String   // "Messi vs Ronaldo"
  shortAnswer   String?  @map("short_answer") @db.Text // answer-first summary
  keyDifferences Json?   @map("key_differences") // structured differences
  verdict       String?  @db.Text // conclusion/verdict
  content       Json?    // full structured content blocks
  category      String?  // "soccer", "countries", "phones"

  // Entities in this comparison
  entities      ComparisonEntity[]

  // SEO
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")
  schemaMarkup    Json?    @map("schema_markup")

  // Internal linking
  relatedComparisonIds String[] @map("related_comparison_ids")

  // Status & quality
  status          String   @default("draft") // draft, review, published, archived
  contentScore    Float?   @map("content_score") // quality score 0-100
  isAutoGenerated Boolean  @default(false) @map("is_auto_generated")
  isHumanReviewed Boolean  @default(false) @map("is_human_reviewed")
  reviewedBy      String?  @map("reviewed_by")
  reviewedAt      DateTime? @map("reviewed_at")

  // Engagement
  viewCount       Int      @default(0) @map("view_count")
  searchImpressions Int    @default(0) @map("search_impressions")

  // Freshness
  publishedAt     DateTime? @map("published_at")
  lastRefreshedAt DateTime? @map("last_refreshed_at")
  nextRefreshAt   DateTime? @map("next_refresh_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Related
  faqs            FAQ[]
  changeLogs      ChangeLog[]

  @@index([status])
  @@index([category])
  @@index([slug])
  @@index([viewCount])
  @@map("comparisons")
}

model ComparisonEntity {
  id           String   @id @default(cuid())
  comparisonId String   @map("comparison_id")
  comparison   Comparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  entityId     String   @map("entity_id")
  entity       Entity   @relation("ComparisonEntityA", fields: [entityId], references: [id])
  position     Int      @default(0) // order in comparison (0 = left, 1 = right)
  pros         String[] // pros for this entity in this comparison
  cons         String[] // cons for this entity
  bestFor      String?  @map("best_for") // "Best for competitive players"

  @@unique([comparisonId, entityId])
  @@index([comparisonId])
  @@index([entityId])
  @@map("comparison_entities")
}

// ============================================================
// FAQ SYSTEM
// ============================================================

model FAQ {
  id           String   @id @default(cuid())
  question     String
  answer       String   @db.Text
  entityId     String?  @map("entity_id")
  entity       Entity?  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  comparisonId String?  @map("comparison_id")
  comparison   Comparison? @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  sortOrder    Int      @default(0) @map("sort_order")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([entityId])
  @@index([comparisonId])
  @@map("faqs")
}

// ============================================================
// KEYWORD INTELLIGENCE SYSTEM
// ============================================================

model KeywordOpportunity {
  id               String   @id @default(cuid())
  keyword          String
  searchVolume     Int?     @map("search_volume")
  cpc              Float?
  competition      Float?   // 0-1
  difficulty       Float?   // 0-100
  intent           String?  // informational, commercial, navigational
  category         String?
  entityTypeSlug   String?  @map("entity_type_slug")

  // Parsed entities from keyword
  entityA          String?  @map("entity_a")
  entityB          String?  @map("entity_b")
  queryPattern     String?  @map("query_pattern") // "vs", "alternative", "compare", "difference"

  // Scoring
  opportunityScore Float?   @map("opportunity_score") // composite score
  hasExistingPage  Boolean  @default(false) @map("has_existing_page")
  existingPageId   String?  @map("existing_page_id")

  // Source
  source           String?  // "dataforseo", "manual", "competitor_scan"
  sourceData       Json?    @map("source_data")

  // Cluster
  clusterId        String?  @map("cluster_id")
  cluster          KeywordCluster? @relation(fields: [clusterId], references: [id])

  // Status
  status           String   @default("discovered") // discovered, queued, building, published, rejected
  processedAt      DateTime? @map("processed_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@unique([keyword])
  @@index([status])
  @@index([opportunityScore])
  @@index([category])
  @@index([queryPattern])
  @@map("keyword_opportunities")
}

model KeywordCluster {
  id          String   @id @default(cuid())
  name        String
  category    String?
  pillarKeyword String? @map("pillar_keyword")
  keywords    KeywordOpportunity[]
  totalVolume Int?     @map("total_volume")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("keyword_clusters")
}

// ============================================================
// COMPETITOR INTELLIGENCE
// ============================================================

model CompetitorDomain {
  id          String   @id @default(cuid())
  domain      String   @unique
  name        String?
  description String?
  categories  String[] // what types of comparisons they cover
  authority   Float?   // domain authority score
  pages       CompetitorPage[]

  lastScannedAt DateTime? @map("last_scanned_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("competitor_domains")
}

model CompetitorPage {
  id           String   @id @default(cuid())
  url          String   @unique
  domainId     String   @map("domain_id")
  domain       CompetitorDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  title        String?
  h1           String?
  category     String?
  entityTypes  String[] @map("entity_types")
  urlPattern   String?  @map("url_pattern")
  titlePattern String?  @map("title_pattern")
  hasTable     Boolean  @default(false) @map("has_table")
  hasSchema    Boolean  @default(false) @map("has_schema")
  hasFaq       Boolean  @default(false) @map("has_faq")
  contentBlocks Json?   @map("content_blocks")
  analysis     Json?

  lastScannedAt DateTime? @map("last_scanned_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([domainId])
  @@map("competitor_pages")
}

// ============================================================
// CONTENT OPERATIONS
// ============================================================

model ContentBrief {
  id             String   @id @default(cuid())
  title          String
  slug           String?
  category       String?
  entityTypeSlug String?  @map("entity_type_slug")
  entityA        String?  @map("entity_a")
  entityB        String?  @map("entity_b")
  keywordIds     String[] @map("keyword_ids")
  brief          Json?    // structured brief content
  templateId     String?  @map("template_id")

  // Status
  status         String   @default("pending") // pending, approved, generating, published, rejected
  priority       Int      @default(0)
  assignedTo     String?  @map("assigned_to")

  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([priority])
  @@map("content_briefs")
}

model RefreshJob {
  id           String   @id @default(cuid())
  jobType      String   @map("job_type") // "keyword_discovery", "competitor_scan", "page_refresh", "link_build"
  status       String   @default("pending") // pending, running, completed, failed
  config       Json?
  result       Json?
  error        String?
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([status])
  @@index([jobType])
  @@map("refresh_jobs")
}

// ============================================================
// INTERNAL LINKING
// ============================================================

model InternalLink {
  id           String   @id @default(cuid())
  fromEntityId String?  @map("from_entity_id")
  fromEntity   Entity?  @relation("InternalLinkFrom", fields: [fromEntityId], references: [id])
  toEntityId   String?  @map("to_entity_id")
  toEntity     Entity?  @relation("InternalLinkTo", fields: [toEntityId], references: [id])
  fromPath     String   @map("from_path")
  toPath       String   @map("to_path")
  anchorText   String   @map("anchor_text")
  linkType     String   @map("link_type") // "related", "alternative", "category", "trending"
  position     String?  // "sidebar", "footer", "inline", "module"
  score        Float?   @default(1.0) // relevance score

  createdAt    DateTime @default(now()) @map("created_at")

  @@index([fromPath])
  @@index([toPath])
  @@index([linkType])
  @@map("internal_links")
}

// ============================================================
// API KEY MANAGEMENT & SUBSCRIPTIONS
// ============================================================

model ApiKey {
  id             String   @id @default(cuid())
  key            String   @unique // hashed API key
  keyPrefix      String   @map("key_prefix") // first 8 chars for display: "avsb_xxxx..."
  name           String   // user-given name: "Production", "Staging"
  email          String   // subscriber email
  tier           String   @default("free") // free, pro, enterprise
  status         String   @default("active") // active, revoked, expired

  // Rate limits (overrides from tier defaults if set)
  dailyLimit     Int?     @map("daily_limit")

  // Stripe
  stripeCustomerId     String?  @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")

  // Usage tracking
  requestsToday  Int      @default(0) @map("requests_today")
  requestsTotal  Int      @default(0) @map("requests_total")
  lastUsedAt     DateTime? @map("last_used_at")
  lastResetAt    DateTime  @default(now()) @map("last_reset_at")

  // Timestamps
  expiresAt      DateTime? @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  usageLogs      ApiUsageLog[]

  @@index([email])
  @@index([tier])
  @@index([status])
  @@map("api_keys")
}

model ApiUsageLog {
  id        String   @id @default(cuid())
  apiKeyId  String   @map("api_key_id")
  apiKey    ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  endpoint  String   // "/api/v1/comparisons", "/api/v1/comparisons/:slug"
  method    String   @default("GET")
  statusCode Int     @map("status_code")
  responseMs Int?    @map("response_ms")
  ip        String?
  userAgent String?  @map("user_agent")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([apiKeyId])
  @@index([createdAt])
  @@index([apiKeyId, createdAt])
  @@map("api_usage_logs")
}

// ============================================================
// AUDIT & CHANGE TRACKING
// ============================================================

model ChangeLog {
  id           String   @id @default(cuid())
  entityType   String   @map("entity_type") // "comparison", "entity", "keyword"
  entityId     String   @map("entity_id")
  action       String   // "created", "updated", "published", "archived"
  changes      Json?
  performedBy  String?  @map("performed_by")
  comparisonId String?  @map("comparison_id")
  comparison   Comparison? @relation(fields: [comparisonId], references: [id])

  createdAt    DateTime @default(now()) @map("created_at")

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("change_logs")
}

// ============================================================
// COMPARISON POLLS / VOTING
// ============================================================

model ComparisonVote {
  id           String   @id @default(cuid())
  comparisonId String   @map("comparison_id")
  entityChoice String   @map("entity_choice") // entity name chosen
  sessionId    String   @map("session_id")    // cookie-based session
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([comparisonId, sessionId])
  @@index([comparisonId])
  @@map("comparison_votes")
}

// ============================================================
// CATEGORIES
// ============================================================

model Category {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  icon        String?
  parentId    String?  @map("parent_id")
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  sortOrder   Int      @default(0) @map("sort_order")

  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("categories")
}

// ============================================================
// NEWSLETTER SUBSCRIBERS
// ============================================================

model NewsletterSubscriber {
  id           String   @id @default(cuid())
  email        String   @unique
  source       String?  // "footer", "comparison", "homepage", "blog"
  referrerSlug String?  @map("referrer_slug") // which page they signed up from
  status       String   @default("active") // active, unsubscribed
  subscribedAt DateTime @default(now()) @map("subscribed_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([source])
  @@map("newsletter_subscribers")
}

// ============================================================
// BLOG SYSTEM
// ============================================================

model BlogArticle {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  excerpt       String?  @db.Text
  content       String   @db.Text  // markdown content
  category      String?
  tags          String[]

  // SEO
  metaTitle       String?  @map("meta_title")
  metaDescription String?  @map("meta_description")

  // Source
  sourceQuery     String?  @map("source_query")  // GSC query that triggered this
  sourceImpressions Int?   @map("source_impressions")

  // Related comparisons
  relatedComparisonSlugs String[] @map("related_comparison_slugs")

  // Status
  status          String   @default("draft")  // draft, published, archived
  isAutoGenerated Boolean  @default(true) @map("is_auto_generated")

  // Engagement
  viewCount       Int      @default(0) @map("view_count")

  // Timestamps
  publishedAt     DateTime? @map("published_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([category])
  @@index([slug])
  @@map("blog_articles")
}

// ============================================================
// CONTENT SYNDICATION SYSTEM
// ============================================================

model SyndicatedContent {
  id              String   @id @default(cuid())

  // Source content reference (comparison or blog article)
  sourceType      String   @map("source_type")   // "comparison" | "blog"
  sourceSlug      String   @map("source_slug")    // slug of the comparison or blog
  sourceTitle     String   @map("source_title")

  // Syndication target
  platform        String   // "medium" | "devto" | "linkedin"
  platformUrl     String?  @map("platform_url")   // URL on the target platform once published
  canonicalUrl    String   @map("canonical_url")   // https://www.aversusb.net/compare/... or /blog/...

  // Formatted content ready for publishing
  formattedTitle  String   @map("formatted_title")
  formattedBody   String   @db.Text @map("formatted_body") // markdown/html for the platform

  // Status tracking
  status          String   @default("pending")  // pending, published, failed, skipped
  publishedAt     DateTime? @map("published_at")
  errorMessage    String?  @map("error_message")

  // Referral tracking
  utmCampaign     String?  @map("utm_campaign")
  utmSource       String?  @map("utm_source")
  referralClicks  Int      @default(0) @map("referral_clicks")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([sourceSlug, platform])
  @@index([status])
  @@index([platform])
  @@index([sourceType])
  @@map("syndicated_content")
}

// ============================================================
// EMBED PARTNER SYSTEM — White-label embed widget for partners
// ============================================================

// ============================================================
// SMARTREVIEW — Product reviews & ratings
// ============================================================

model ProductReview {
  id           String   @id @default(cuid())
  entityId     String   @map("entity_id")
  entity       Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  // Review content
  source       String   // "reddit", "g2", "capterra", "trustpilot", "producthunt", "tavily"
  sourceUrl    String?  @map("source_url")
  authorName   String?  @map("author_name")
  rating       Float?   // 0-5 normalized rating
  title        String?
  body         String?  @db.Text
  pros         String[]
  cons         String[]

  // Metadata
  sourceDate   DateTime? @map("source_date") // when the review was originally posted
  sentiment    Float?   // -1 to 1 sentiment score
  isVerified   Boolean  @default(false) @map("is_verified")
  status       String   @default("active") // active, flagged, hidden

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([entityId])
  @@index([source])
  @@index([status])
  @@index([entityId, source])
  @@map("product_reviews")
}

model ReviewAggregation {
  id            String   @id @default(cuid())
  entityId      String   @unique @map("entity_id")
  entity        Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)

  // Aggregated scores
  averageRating Float    @map("average_rating") // 0-5
  totalReviews  Int      @map("total_reviews")
  smartScore    Int      @default(0) @map("smart_score") // 0-100 composite score

  // Per-source breakdown
  sourceBreakdown Json?  @map("source_breakdown") // { "reddit": { avg: 4.2, count: 15 }, ... }

  // Sentiment
  avgSentiment  Float?   @map("avg_sentiment") // -1 to 1
  positivePct   Float?   @map("positive_pct") // 0-100
  negativePct   Float?   @map("negative_pct") // 0-100

  // Common themes
  topPros       String[] @map("top_pros")
  topCons       String[] @map("top_cons")

  // Freshness
  lastAggregatedAt DateTime @default(now()) @map("last_aggregated_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([averageRating])
  @@index([smartScore])
  @@map("review_aggregations")
}

model EmbedPartner {
  id              String   @id @default(cuid())
  partnerKey      String   @unique @map("partner_key") // public key used in embed URLs
  name            String   // partner company name
  email           String
  website         String?  // partner's website URL
  tier            String   @default("free") // free, pro, enterprise
  status          String   @default("active") // active, suspended, cancelled

  // White-label branding
  brandName       String?  @map("brand_name") // replaces "A Versus B" in footer
  primaryColor    String?  @map("primary_color") // hex color for header gradient start
  accentColor     String?  @map("accent_color") // hex color for header gradient end
  logoUrl         String?  @map("logo_url") // partner logo URL for embed header
  hideBranding    Boolean  @default(false) @map("hide_branding") // hide "Powered by" footer
  customFooterText String? @map("custom_footer_text") // custom footer text
  customFooterUrl  String? @map("custom_footer_url") // custom footer link URL

  // Allowed categories/comparisons (null = all)
  allowedCategories String[] @map("allowed_categories")
  featuredSlugs     String[] @map("featured_slugs") // pinned comparisons for this partner

  // Usage limits
  monthlyEmbedViews  Int     @default(0) @map("monthly_embed_views")
  monthlyViewLimit   Int?    @map("monthly_view_limit") // null = unlimited
  lastViewResetAt    DateTime @default(now()) @map("last_view_reset_at")

  // Stripe billing
  stripeCustomerId     String?  @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")

  // Timestamps
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([email])
  @@index([tier])
  @@index([status])
  @@map("embed_partners")
}

// ============================================================
// AFFILIATE LINK MANAGEMENT & CLICK TRACKING
// ============================================================

model AffiliateLink {
  id              String    @id @default(cuid())
  entityId        String    @map("entity_id")
  entity          Entity    @relation(fields: [entityId], references: [id], onDelete: Cascade)
  partner         String    // "amazon", "impact", "shareasale", "brand_direct"
  url             String
  label           String
  priority        Int       @default(0) // higher = shown first
  isActive        Boolean   @default(true) @map("is_active")
  expiresAt       DateTime? @map("expires_at")
  lastValidatedAt DateTime? @map("last_validated_at")
  source          String    @default("manual") // "manual", "import", "generated"
  metadata        Json?

  clicks          AffiliateClick[]

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([entityId, partner])
  @@index([entityId])
  @@index([isActive])
  @@index([expiresAt])
  @@map("affiliate_links")
}

model AffiliateClick {
  id              String   @id @default(cuid())
  affiliateLinkId String?  @map("affiliate_link_id")
  affiliateLink   AffiliateLink? @relation(fields: [affiliateLinkId], references: [id], onDelete: SetNull)
  entityId        String   @map("entity_id")
  entity          Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  comparisonSlug  String   @map("comparison_slug")
  affiliateNetwork String  @map("affiliate_network")
  sessionId       String   @map("session_id")
  source          String?  // "hero_cta", "sticky_cta", "where_to_buy", "attribute_row"
  metadata        Json?

  createdAt       DateTime @default(now()) @map("created_at")

  @@index([entityId])
  @@index([comparisonSlug])
  @@index([createdAt])
  @@index([affiliateLinkId])
  @@map("affiliate_clicks")
}
