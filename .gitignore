# local env files
# Catch-all: `.env*.local` missed suffixed dumps like `.env.vercel.local.fresh`
# (a `vercel env pull` target holding live Neon credentials). DAN-1513 was that
# leak. Ignore every .env* and re-admit the one committed template.
.env*
!.env.example
.env*.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# YouTube API secrets (never commit)
scripts/google-credentials.json
scripts/youtube-token.json

# HyperFrames per-render artifacts (regenerated each run)
hyperframes/comparison-video/index.html
hyperframes/comparison-video/narration*.mp3
hyperframes/comparison-video/narration*.wav
hyperframes/comparison-video/transcript.json
hyperframes/comparison-video/script.txt
hyperframes/comparison-video/bg-music.mp3
hyperframes/comparison-video/renders/
hyperframes/**/.hyperframes/

# Local-only render outputs (uploaded to YouTube + copied to public/videos)
/Videos For Website/
.env.prod
.env.vercel.production
.env.local
.env.vercel.prod
.env.production

# Local data snapshots (large JSON, not for version control)
scripts/data/*.json
gsc-recovery-daily.json
